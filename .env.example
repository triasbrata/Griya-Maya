# Copy to .env for local development, then just: `make run`
# (the server auto-loads .env via godotenv; already-set env vars are never overwritten)

# --- HTTP ---
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# --- Cloudflare D1 (REST API) ---
CF_ACCOUNT_ID=
D1_DATABASE_ID=
CF_API_TOKEN=          # token with D1 Edit permission

# --- Cloudflare R2 (S3 API) ---
R2_BUCKET=manga
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Leave empty (recommended): bucket stays private, page URLs are presigned.
# Keep any comment on its OWN line — godotenv captures an inline comment on the
# assignment line as the value when the value is empty.
R2_PUBLIC_BASE_URL=
PRESIGN_TTL_SEC=3600   # lifetime of presigned page URLs; track access-token TTL (SigV4 max 604800)
# S3-compatible override: set S3_ENDPOINT to target MinIO/self-hosted S3 instead
# of R2 (e.g. http://localhost:9000). Leave empty for R2 (endpoint derived from
# CF_ACCOUNT_ID). Region defaults to "auto" for R2; MinIO usually wants us-east-1.
# Keep any comment on its OWN line (see R2_PUBLIC_BASE_URL note above).
S3_ENDPOINT=
S3_REGION=

# --- Cloudflare KV (REST API) — short-lived OIDC state (auth requests/codes/tokens) ---
KV_NAMESPACE_ID=              # uses CF_ACCOUNT_ID + CF_API_TOKEN above

# --- Cloudflare Queue (REST API) — async cover-image mirror (external cover -> AVIF in R2) ---
# Queue UUID from `wrangler queues list` (create: `wrangler queues create cover-mirror`,
# enable pull: `wrangler queues consumer http add cover-mirror`). Empty disables mirroring.
# Uses CF_ACCOUNT_ID + CF_API_TOKEN above; the token needs Queues read+write.
COVER_QUEUE_ID=

# --- Cloudflare Queue (REST API) — async R2 cleanup of orphaned page objects ---
# Separate queue UUID (create: `wrangler queues create page-cleanup`, enable pull:
# `wrangler queues consumer http add page-cleanup`). Deleting chapters/pages/media
# removes only the D1 rows; this queue drives the R2 object deletion. Empty
# disables cleanup (rows removed, objects left in R2). Uses CF_ACCOUNT_ID +
# CF_API_TOKEN above; the token needs Queues read+write.
CLEANUP_QUEUE_ID=

# --- Embedded OpenID Provider (zitadel/oidc) ---
OIDC_ISSUER=http://localhost:8080          # externally reachable base URL (== PUBLIC_BASE_URL)
OIDC_CRYPTO_KEY=dev-insecure-32-byte-crypto-key!   # exactly 32 bytes; used to encrypt tokens
OIDC_REQUIRED_SCOPE=manga.write            # scope enforced on ingest/convert routes (reads require manga.read)
OIDC_ACCESS_TTL_SEC=3600
OIDC_REFRESH_TTL_SEC=2592000
OIDC_AUTH_CODE_TTL_SEC=300
OIDC_ADMIN_EMAIL=admin@example.com         # seeded on first boot if admin_user table empty
OIDC_ADMIN_PASSWORD=                       # set to seed the admin (argon2id hashed); empty = no seed
ADMIN_REDIRECT_URIS=http://localhost:3000/auth/callback  # comma-separated; redirect_uris for the seeded admin-web PKCE client
IOS_REDIRECT_URIS=mihon://auth/callback    # comma-separated; redirect_uris for the seeded mihon-ios public PKCE client

# --- WebAuthn / passkey (biometric) login --- (empty WEBAUTHN_RP_ID disables it)
WEBAUTHN_RP_ID=                            # relying-party ID: effective domain, no scheme/port (e.g. griyamedia.brata.cloud)
WEBAUTHN_RP_DISPLAY_NAME=GriyaMedia        # shown by the authenticator during registration
WEBAUTHN_RP_ORIGINS=                       # comma-separated fully-qualified origins: admin-web origin(s) + https://<rp-id> for iOS
WEBAUTHN_APPLE_APP_IDS=                    # comma-separated Apple app IDs TEAMID.BUNDLEID; served in apple-app-site-association for native iOS

# --- External-source OAuth connections (MyAnimeList; later IMDB) ---
CONNECTIONS_ENC_KEY=dev-insecure-32-byte-conn-key!!!   # exactly 32 bytes; AES-256-GCM key for connection secrets/tokens at rest

# --- AVIF conversion tuning ---
AVIF_QUALITY=55
AVIF_SPEED=6
AVIF_MAX_EDGE=2048
CONVERT_TIMEOUT_SEC=600
