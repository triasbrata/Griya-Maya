# Copy to .env for local development, then just: `make run`
# (the server auto-loads .env via godotenv; already-set env vars are never overwritten)

# --- HTTP ---
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# --- Cloudflare D1 (REST API) ---
CF_ACCOUNT_ID=
D1_DATABASE_ID=
CF_API_TOKEN=          # token with D1 Edit permission

# --- Cloudflare R2 (S3 API) ---
R2_BUCKET=manga
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=    # leave empty (recommended): bucket stays private, page URLs are presigned
PRESIGN_TTL_SEC=3600   # lifetime of presigned page URLs; track access-token TTL (SigV4 max 604800)

# --- Cloudflare KV (REST API) — short-lived OIDC state (auth requests/codes/tokens) ---
KV_NAMESPACE_ID=              # uses CF_ACCOUNT_ID + CF_API_TOKEN above

# --- Embedded OpenID Provider (zitadel/oidc) ---
OIDC_ISSUER=http://localhost:8080          # externally reachable base URL (== PUBLIC_BASE_URL)
OIDC_CRYPTO_KEY=dev-insecure-32-byte-crypto-key!   # exactly 32 bytes; used to encrypt tokens
OIDC_REQUIRED_SCOPE=manga.write            # scope enforced on ingest/convert routes (reads require manga.read)
OIDC_ACCESS_TTL_SEC=3600
OIDC_REFRESH_TTL_SEC=2592000
OIDC_AUTH_CODE_TTL_SEC=300
OIDC_ADMIN_EMAIL=admin@example.com         # seeded on first boot if admin_user table empty
OIDC_ADMIN_PASSWORD=                       # set to seed the admin (argon2id hashed); empty = no seed
ADMIN_REDIRECT_URIS=http://localhost:3000/auth/callback  # comma-separated; redirect_uris for the seeded admin-web PKCE client
IOS_REDIRECT_URIS=mihon://auth/callback    # comma-separated; redirect_uris for the seeded mihon-ios public PKCE client

# --- AVIF conversion tuning ---
AVIF_QUALITY=55
AVIF_SPEED=6
AVIF_MAX_EDGE=2048
CONVERT_TIMEOUT_SEC=600
