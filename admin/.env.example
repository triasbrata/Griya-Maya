# Copy to .env — Vite exposes VITE_* to the browser.

# Issuer = the manga-server OpenID Provider (embedded IdP).
VITE_OIDC_ISSUER=http://localhost:8080
VITE_OIDC_CLIENT_ID=admin-web
VITE_OIDC_SCOPE=openid profile email offline_access manga.write

# manga-server API base (empty = same origin as issuer when co-hosted).
VITE_API_BASE=http://localhost:8080
